# Required: server-side key for GraphHopper routing + geocoding.
# Get one free at https://www.graphhopper.com/  ->  Dashboard -> API Keys
GRAPHHOPPER_API_KEY=

# Optional: MapTiler key for a detailed street basemap.
# Without it, the app falls back to low-detail MapLibre demo tiles.
# Get one free at https://www.maptiler.com/
NEXT_PUBLIC_MAPTILER_KEY=
